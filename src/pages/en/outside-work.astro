---
import Base from '../../layouts/Base.astro';
import DividerBar from '../../components/DividerBar.astro';

const interests = [
  'Photography',
  'Cooking',
  'Jiu-jitsu',
  'Hiking',
  'Animals',
  'Plants',
  'Agroforestry',
];
---

<Base title="Outside work — Lemuel Monteiro">
  <section class="container hero">
    <h1 class="hero__title">OUTSIDE WORK</h1>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="quote">
      Trying to find my place in a new world every day, with curiosity and resilience.
    </p>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="label">Interests</p>
    <ul class="interests">
      {interests.map((interest) => (
        <li class="interest">{interest}</li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(48px, 6vw, 80px) clamp(32px, 4vw, 48px);
  }

  .hero__title {
    font-size: var(--fs-case-title);
    letter-spacing: -0.01em;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .quote {
    font-size: var(--fs-lead);
    line-height: 1.45;
    max-width: var(--content-max);
  }

  .interests {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px 48px;
    max-width: var(--content-max);
    margin-top: 8px;
  }

  .interest {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-list-title);
    line-height: 1.2;
    padding-left: 24px;
    position: relative;
  }

  .interest::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 10px;
    height: 2px;
    background: var(--accent);
  }

  @media (max-width: 640px) {
    .interests {
      grid-template-columns: 1fr;
    }
  }
</style>
