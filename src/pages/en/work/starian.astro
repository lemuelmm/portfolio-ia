---
import Base from '../../../layouts/Base.astro';
import DividerBar from '../../../components/DividerBar.astro';
import HeroBar from '../../../components/HeroBar.astro';

const tools = [
  'Discovery with analytics (Mixpanel, Amplitude) before Figma',
  'Qualitative research with users and channel partners',
  'Material UI (MUI X Data Grid) for table and bulk-editing patterns',
  'Google Stitch as a component-exploration tool',
  'Explicit benchmarking (Expensify, Linear, Superhuman, QuickBooks)',
];
---

<Base title="Starian · Sienge — Lemuel Monteiro">
  <div class="container back">
    <a href="/en" class="back__link">← Work</a>
  </div>

  <section class="container hero">
    <HeroBar />
    <div class="hero__content">
      <h1 class="hero__title">STARIAN · SIENGE</h1>
      <p class="hero__subtitle">Product Designer</p>
      <p class="hero__meta">May 2025 to present · Remote</p>
    </div>
    <div class="hero__slot">
      <div class="proto__wrapper">
        <iframe
          src="/sienge/titulos-ia.html"
          title="Prototype — AI-assisted payable-entry creation in Sienge"
          class="proto__frame"
          loading="lazy"
        ></iframe>
      </div>
      <p class="proto__caption">Working prototype built with AI — interact with it directly in the frame</p>
    </div>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="label">Context</p>
    <p class="section__body">
      I work on Sienge (a construction-industry SaaS with over 25 years on the market), on the
      KillBills / Accounts Payable team within the Financial Journey. I joined through Softplan in
      May 2025 and stayed with Starian after the spin-off in August of the same year.
    </p>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="label">Discovery in progress</p>
    <p class="section__body">
      I'm currently running discovery on the next version of AI-assisted payable-entry creation, focused on a
      bulk workflow: uploading multiple documents, automatic field extraction and sequential review.
      I work with dense interfaces for power users, keyboard navigation as a principle, and a CSD
      matrix to structure certainties, suppositions and doubts before opening Figma.
    </p>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="label">Active themes and tools</p>
    <ul class="tools">
      {tools.map((tool) => (
        <li class="tools__item">{tool}</li>
      ))}
    </ul>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section next">
    <p class="label">Next case</p>
    <a href="/en/work/geopark" class="next__link">
      <span>GEOPARK ARARIPE</span>
      <span aria-hidden="true"> →</span>
    </a>
  </section>
</Base>

<style>
  .back {
    padding-top: 8px;
    padding-bottom: 32px;
  }

  .back__link {
    font-size: var(--fs-small);
    color: var(--accent);
  }

  .hero {
    position: relative;
    padding-block: clamp(48px, 6vw, 80px) clamp(48px, 6vw, 80px);
    padding-left: calc(var(--pad-x) + 24px);
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: var(--content-max);
  }

  .hero__title {
    font-size: var(--fs-case-title);
    letter-spacing: -0.01em;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--fs-lead);
    color: var(--text);
  }

  .hero__meta {
    font-size: var(--fs-small);
    color: var(--text-muted);
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .section__body {
    font-size: var(--fs-body);
    line-height: 1.6;
    max-width: var(--content-max);
  }

  .tools {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--content-max);
  }

  .tools__item {
    font-size: var(--fs-body);
    line-height: 1.6;
    padding-left: 24px;
    position: relative;
  }

  .tools__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 8px;
    height: 2px;
    background: var(--accent);
  }

  .proto__wrapper {
    width: 100%;
    aspect-ratio: 16/9;
    border: 1px solid var(--divider);
    border-radius: 4px;
    overflow: hidden;
    background: #F7F7F7;
  }

  .proto__frame {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .proto__caption {
    margin-top: 10px;
    font-size: var(--fs-small);
    color: var(--text-muted);
  }

  .next__link {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-next-case);
    color: var(--text);
    text-decoration: none;
    width: max-content;
    max-width: 100%;
  }

  .next__link:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
    text-decoration-color: var(--accent);
  }
</style>
