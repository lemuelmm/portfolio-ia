---
import Base from '../../layouts/Base.astro';
import DividerBar from '../../components/DividerBar.astro';

const skills = [
  {
    number: '01',
    title: 'Data-driven discovery',
    description: 'Analytics + qualitative research.',
  },
  {
    number: '02',
    title: 'Interface design for operations',
    description: 'Power users, information density, keyboard navigation.',
  },
  {
    number: '03',
    title: 'Products with social and environmental impact',
    description: 'Sustainability as practice, not as a slogan.',
  },
  {
    number: '04',
    title: 'Iterative prototyping in Figma + AI',
    description:
      'Using AI as a tool for exploration and rough drafts before refining in Figma.',
  },
];

const habits = [
  {
    title: 'Confirmation before the pixel',
    description:
      'I use a CSD matrix to separate certainties, suppositions and doubts before opening Figma.',
  },
  {
    title: 'Data first',
    description:
      'I read usage analytics before proposing any change. When the data falls short, I bring in qualitative research.',
  },
  {
    title: 'AI as an exploration tool',
    description:
      'I use Claude and Google Stitch to draft artifacts and explore components before refining in Figma.',
  },
  {
    title: 'Iterative building',
    description:
      'Prototypes evolve through short validation cycles, not in a single handoff.',
  },
];

const certifications = [
  'Google UX Design (Coursera)',
  'Design for the 21st Century with Don Norman (IxDF)',
  'EFSET B2 (Upper Intermediate English)',
];
---

<Base title="About — Lemuel Monteiro">
  <section class="container hero">
    <h1 class="hero__title">ABOUT</h1>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="label">Bio</p>
    <div class="bio">
      <p class="section__body">
        I'm Lemuel Monteiro, a Brazilian Product Designer. Today I work at Starian (formerly Softplan),
        on the Sienge product, designing accounts-payable interfaces for the construction industry,
        focused on dense workflows for power users.
      </p>
      <p class="section__body">
        Before that, I worked at Youse Seguros through BOLD Brasil, on authentication projects (migrating
        login to the Brazilian taxpayer ID, CPF, with security questions) and on the CO2 Calculator
        product, which grew into a standalone environmental-awareness solution.
      </p>
      <p class="section__body">
        Since my degree in Information Systems, I've kept a consistent track record in projects with
        social and environmental impact: Geopark Araripe (UNESCO), where I led the digitization of the
        environmental assessment processes, and GIR, where I contributed as a volunteer to a
        waste-management platform.
      </p>
      <p class="section__body">
        My practice combines rigor in decision-making (research with data, a CSD matrix, validating
        before the first pixel) with attention to what the product leaves behind in the world.
      </p>
    </div>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="label">Skills</p>
    <ol class="skills">
      {skills.map((skill) => (
        <li class="skill">
          <span class="skill__number" aria-hidden="true">{skill.number}</span>
          <div class="skill__content">
            <h3 class="skill__title">{skill.title}</h3>
            <p class="skill__description">{skill.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="label">How I work</p>
    <p class="section__body">
      I start with confirmation: I don't design until I'm clear on the problem. In practice,
      four habits:
    </p>
    <ul class="habits">
      {habits.map((habit) => (
        <li class="habit">
          <h3 class="habit__title">{habit.title}</h3>
          <p class="habit__description">{habit.description}</p>
        </li>
      ))}
    </ul>
  </section>

  <div class="container">
    <DividerBar />
  </div>

  <section class="container section">
    <p class="label">Education</p>
    <div class="education">
      <div class="education__block">
        <h3 class="education__heading">Degree</h3>
        <p class="section__body">
          Bachelor's in Information Systems · UniFAP · 2017 to 2021
        </p>
      </div>
      <div class="education__block">
        <h3 class="education__heading">Certifications</h3>
        <ul class="certifications">
          {certifications.map((cert) => (
            <li class="certification">{cert}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(48px, 6vw, 80px) clamp(32px, 4vw, 48px);
  }

  .hero__title {
    font-size: var(--fs-case-title);
    letter-spacing: -0.01em;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .section__body {
    font-size: var(--fs-body);
    line-height: 1.6;
    max-width: var(--content-max);
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .skills {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin-top: 8px;
  }

  .skill {
    display: grid;
    grid-template-columns: minmax(auto, 80px) 1fr;
    gap: 24px;
    align-items: baseline;
  }

  .skill__number {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-list-title);
    color: var(--accent);
  }

  .skill__content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: var(--content-max);
  }

  .skill__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-list-title);
    line-height: 1.2;
  }

  .skill__description {
    font-size: var(--fs-body);
    line-height: 1.6;
  }

  .habits {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin-top: 8px;
  }

  .habit {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: var(--content-max);
  }

  .habit__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-list-title);
    line-height: 1.2;
  }

  .habit__description {
    font-size: var(--fs-body);
    line-height: 1.6;
  }

  .education {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .education__block {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--content-max);
  }

  .education__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-list-title);
    line-height: 1.2;
  }

  .certifications {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .certification {
    font-size: var(--fs-body);
    line-height: 1.6;
    padding-left: 24px;
    position: relative;
  }

  .certification::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 8px;
    height: 2px;
    background: var(--accent);
  }

  @media (max-width: 640px) {
    .skill {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
