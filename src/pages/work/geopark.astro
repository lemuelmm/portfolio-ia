---
import Base from '../../layouts/Base.astro';
import DividerBar from '../../components/DividerBar.astro';
import HeroBar from '../../components/HeroBar.astro';
import ImpactBlock from '../../components/ImpactBlock.astro';

const CDN = 'https://cdn.prod.website-files.com/61e2d593fa26ee0bf9afa87a';
const img = {
  hero:            `${CDN}/628143069a1231736ecfa8d7_Frame%203cover.png`,
  contexto:        `${CDN}/6214212d77998341bdf05b55_Frame%201.png`,
  appTelas:        `${CDN}/6667047335d72661d18358e3_2.png`,
  painelWeb:       `${CDN}/666703044cb7f8b601e775e7_3.png`,
  antesDepoisNav:  `${CDN}/66670304879a1635764752da_4.png`,
  antesDepoisLogin:`${CDN}/66670305b850b221188b7a1b_5.png`,
};

const chapters = [
  {
    number: '01',
    title: 'Graduação (NexTI)',
    description: 'Primeiro contato, estruturação do problema e protótipo inicial de solução.',
  },
  {
    number: '02',
    title: 'Período voluntário',
    description: 'Retomada por conta própria, com refinamentos baseados em experiências acumuladas no mercado.',
  },
  {
    number: '03',
    title: '2024 com a instituição',
    description: 'Liderança direta da implementação da solução digital, dentro da estrutura do Geopark.',
  },
];

const approach = [
  {
    title: 'Liderança de time',
    description: 'Coordenação do time de desenvolvimento em ciclos ágeis.',
  },
  {
    title: 'Definição de escopo',
    description: 'Identificação da necessidade de uma fórmula matemática para mensurar as condições dos locais avaliados, gerando relatórios mais precisos para os gestores.',
  },
  {
    title: 'Pesquisa e design',
    description: 'Entrevistas com stakeholders (avaliadores e gestores), protótipos de alta fidelidade e testes de usabilidade.',
  },
];
---

<Base title="Geopark Araripe — Lemuel Monteiro">
  <div class="container back">
    <a href="/" class="back__link">← Trabalhos</a>
  </div>

  <!-- HERO -->
  <section class="container hero">
    <HeroBar />
    <div class="hero__content">
      <h1 class="hero__title">GEOPARK ARARIPE</h1>
      <p class="hero__subtitle">Designer de Produtos</p>
      <p class="hero__meta">Abr. 2024 a Dez. 2024 · Crato, CE</p>
    </div>
    <img
      src={img.hero}
      alt="Telas do aplicativo Geopark Araripe — App & Web"
      class="hero__img"
      loading="eager"
    />
  </section>

  <div class="container"><DividerBar /></div>

  <!-- CONTEXTO -->
  <section class="container section">
    <p class="label">Contexto</p>
    <p class="section__body">
      Atuei no Geopark Araripe, instituição ligada à UNESCO que atua como catalisador de
      transformação sustentável na região do Cariri cearense (área que engloba a Floresta Nacional
      do Araripe, a primeira FLONA do Brasil). O foco do projeto era digitalizar os processos de
      avaliação das áreas de preservação.
    </p>
    <img
      src={img.contexto}
      alt="Mapa do Geoparque Araripe e foto do Geossítio Ponte de Pedra"
      class="section__img"
      loading="lazy"
    />
  </section>

  <div class="container"><DividerBar /></div>

  <!-- HISTÓRICO -->
  <section class="container section">
    <p class="label">Histórico do projeto</p>
    <p class="section__body">
      Esse projeto atravessou três fases da minha trajetória, e cada retomada trouxe refinamentos
      baseados no que eu tinha aprendido no intervalo:
    </p>
    <ol class="chapters">
      {chapters.map((ch) => (
        <li class="chapter">
          <span class="chapter__number" aria-hidden="true">{ch.number}</span>
          <div class="chapter__content">
            <h3 class="chapter__title">{ch.title}</h3>
            <p class="chapter__description">{ch.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <div class="container"><DividerBar /></div>

  <!-- DESAFIO -->
  <section class="container section">
    <p class="label">O desafio</p>
    <p class="section__body">
      O processo manual de avaliação dos locais de preservação, feito com papel e caneta em campo,
      gerava atrasos na coleta e análise dos dados. Esses atrasos comprometiam o planejamento das
      ações de conservação, que é o trabalho central do Geopark.
    </p>
  </section>

  <div class="container"><DividerBar /></div>

  <!-- PESQUISA -->
  <section class="container section">
    <p class="label">Pesquisa</p>
    <p class="section__body">
      A pesquisa revelou um único perfil central: o gestor ambiental que precisa coordenar avaliadores
      em campo e interpretar os dados para tomada de decisão.
    </p>
    <img
      src={`${CDN}/621424c6440ab8e06dfa9a99_proccess.png`}
      alt="Persona Eduardo, Jornada do Usuário e Proposta de Valor do Geoparque"
      class="section__img"
      loading="lazy"
    />
  </section>

  <div class="container"><DividerBar /></div>

  <!-- ABORDAGEM -->
  <section class="container section">
    <p class="label">A abordagem</p>
    <ul class="list-block">
      {approach.map((item) => (
        <li class="list-block__item">
          <h3 class="list-block__title">{item.title}</h3>
          <p class="list-block__description">{item.description}</p>
        </li>
      ))}
    </ul>
  </section>

  <div class="container"><DividerBar /></div>

  <!-- SOLUÇÃO -->
  <section class="container section">
    <p class="label">A solução</p>

    <article class="solution">
      <h3 class="list-block__title">App para avaliadores</h3>
      <p class="list-block__description">
        Ferramenta de coleta em campo, substituindo o caderno e caneta do processo anterior.
      </p>
      <img
        src={img.appTelas}
        alt="Telas do app para avaliadores do Geopark Araripe — antes e depois"
        class="solution__img"
        loading="lazy"
      />
    </article>

    <article class="solution">
      <h3 class="list-block__title">Painel web para gestores</h3>
      <p class="list-block__description">
        Consolidação dos dados, aplicação da fórmula matemática e geração de relatórios para tomada de decisão.
      </p>
      <img
        src={img.painelWeb}
        alt="Painel web para gestores do Geopark Araripe — antes e depois"
        class="solution__img"
        loading="lazy"
      />
    </article>

    <article class="solution">
      <h3 class="list-block__title">Melhorias de navegação e login</h3>
      <p class="list-block__description">
        Refinamentos baseados em testes: redução de telas no fluxo de avaliação e tela de login mais acessível.
      </p>
      <div class="solution__pair">
        <img
          src={img.antesDepoisNav}
          alt="Antes e depois da navegação e status do Geopark"
          class="solution__img"
          loading="lazy"
        />
        <img
          src={img.antesDepoisLogin}
          alt="Antes e depois da tela de login do Geopark"
          class="solution__img"
          loading="lazy"
        />
      </div>
    </article>
  </section>

  <div class="container"><DividerBar /></div>

  <!-- PROTÓTIPO -->
  <section class="container section">
    <p class="label">Protótipo</p>
    <p class="section__body">
      Veja o fluxo completo do aplicativo navegável no Figma.
    </p>
    <a
      href="https://www.figma.com/proto/PClP6HgyBYYx644G5ieH3n/Geoparque?node-id=1180-1782&p=f&viewport=37%2C347%2C0.06&t=S39MDWd6FrfFipfF-1&scaling=scale-down-width&content-scaling=fixed&starting-point-node-id=1180%3A1782&page-id=1180%3A936"
      class="proto__link"
      target="_blank"
      rel="noopener noreferrer"
    >
      Abrir protótipo no Figma →
    </a>
  </section>

  <div class="container"><DividerBar /></div>

  <!-- VÍDEO -->
  <section class="container section">
    <p class="label">Demonstração</p>
    <p class="section__body">
      Walkthrough das telas do aplicativo, gravado em 2024.
    </p>
    <div class="video__wrapper">
      <iframe
        src="https://www.youtube.com/embed/2gF5wNMudb8"
        title="Telas Aplicativo Geopark Araripe 2024"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <ImpactBlock
    number="80%"
    primary="Redução no tempo do processo de avaliação."
    secondary="Ferramenta em fase de testes finais com gestores ambientais ao fim da minha atuação em 2024."
  />

  <section class="container section next">
    <p class="label">Próximo case</p>
    <a href="/work/youse" class="next__link">
      <span>YOUSE SEGUROS</span>
      <span aria-hidden="true"> →</span>
    </a>
  </section>
</Base>

<style>
  .back {
    padding-top: 8px;
    padding-bottom: 32px;
  }

  .back__link {
    font-size: var(--fs-small);
    color: var(--accent);
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding-block: clamp(48px, 6vw, 80px);
    padding-left: calc(var(--pad-x) + 24px);
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: var(--content-max);
  }

  .hero__title {
    font-size: var(--fs-case-title);
    letter-spacing: -0.01em;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--fs-lead);
    color: var(--text);
  }

  .hero__meta {
    font-size: var(--fs-small);
    color: var(--text-muted);
  }

  .hero__img {
    width: 100%;
    border-radius: 4px;
    display: block;
  }

  /* ── SEÇÕES ── */
  .section {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .section__body {
    font-size: var(--fs-body);
    line-height: 1.6;
    max-width: var(--content-max);
  }

  .section__img {
    width: 100%;
    border-radius: 4px;
    display: block;
  }

  /* ── HISTÓRICO ── */
  .chapters {
    display: flex;
    flex-direction: column;
    gap: 64px;
    margin-top: 16px;
  }

  .chapter {
    display: grid;
    grid-template-columns: minmax(auto, 200px) 1fr;
    gap: 32px;
    align-items: start;
  }

  .chapter__number {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-chapter-number);
    line-height: 0.9;
    color: var(--accent);
  }

  .chapter__content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--content-max);
  }

  .chapter__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-list-title);
  }

  .chapter__description {
    font-size: var(--fs-body);
    line-height: 1.6;
  }

  /* ── ABORDAGEM ── */
  .list-block {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .list-block__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--content-max);
  }

  .list-block__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-list-title);
  }

  .list-block__description {
    font-size: var(--fs-body);
    line-height: 1.6;
  }

  /* ── SOLUÇÃO ── */
  .solution {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .solution__img {
    width: 100%;
    border-radius: 4px;
    display: block;
  }

  .solution__pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  /* ── PROTÓTIPO ── */
  .proto__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-body);
    color: var(--accent);
    text-decoration: none;
    border: 2px solid var(--accent);
    padding: 12px 20px;
    width: max-content;
    transition: background 0.15s, color 0.15s;
  }

  .proto__link:hover {
    background: var(--accent);
    color: var(--bg);
  }

  /* ── VÍDEO ── */
  .video__wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
  }

  .video__wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 4px;
  }

  /* ── PRÓXIMO CASE ── */
  .next__link {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-next-case);
    color: var(--text);
    text-decoration: none;
    width: max-content;
    max-width: 100%;
  }

  .next__link:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
    text-decoration-color: var(--accent);
  }

  /* ── RESPONSIVO ── */
  @media (max-width: 640px) {
    .chapter {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .solution__pair {
      grid-template-columns: 1fr;
    }
  }
</style>
