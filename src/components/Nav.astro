---
const items = [
  { label: 'Trabalhos', href: '#' },
  { label: 'Sobre', href: '#' },
  { label: 'Fora do trabalho', href: '#' },
];
---

<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__brand" aria-label="Lemuel Monteiro — Home">
      <span class="nav__brand-full">LEMUEL MONTEIRO</span>
      <img
        src="/favicon.svg"
        alt=""
        aria-hidden="true"
        width="32"
        height="32"
        class="nav__brand-mark"
      />
    </a>

    <ul class="nav__menu">
      {items.map((item, i) => (
        <li class="nav__item">
          {i > 0 && <span class="nav__sep" aria-hidden="true">·</span>}
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    padding-block: 24px;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav__brand {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.04em;
    color: var(--text);
    display: inline-flex;
    align-items: center;
  }

  .nav__brand-full {
    display: inline;
  }

  .nav__brand-mark {
    display: none;
    width: 32px;
    height: 32px;
  }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .nav__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 15px;
  }

  .nav__sep {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .nav__brand-full {
      display: none;
    }
    .nav__brand-mark {
      display: inline-block;
    }
    .nav__item {
      font-size: 14px;
    }
  }
</style>
