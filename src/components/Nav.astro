---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = lang === 'en' ? '/en' : '/';

const items = lang === 'en'
  ? [
      { label: t('nav.works'), href: '/en#work' },
      { label: t('nav.about'), href: '/en/about' },
      { label: t('nav.outsideWork'), href: '/en/outside-work' },
    ]
  : [
      { label: t('nav.works'), href: '/#trabalhos' },
      { label: t('nav.about'), href: '/sobre' },
      { label: t('nav.outsideWork'), href: '/fora-do-trabalho' },
    ];

// Seletor de idioma: cada item leva à contraparte da página atual.
const path = Astro.url.pathname;
const langLinks = [
  { code: 'pt-br' as const, label: t('lang.pt'), href: getLocalizedPath(path, 'pt-br') },
  { code: 'en' as const, label: t('lang.en'), href: getLocalizedPath(path, 'en') },
];
---

<nav class="nav">
  <div class="container nav__inner">
    <a href={home} class="nav__brand" aria-label={t('nav.brandAria')}>
      <span class="nav__brand-full">LEMUEL MONTEIRO</span>
      <img
        src="/favicon.svg"
        alt=""
        aria-hidden="true"
        width="32"
        height="32"
        class="nav__brand-mark"
      />
    </a>

    <div class="nav__right">
      <ul class="nav__menu">
        {items.map((item, i) => (
          <li class="nav__item">
            {i > 0 && <span class="nav__sep" aria-hidden="true">·</span>}
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>

      <div class="nav__lang" role="group" aria-label={t('lang.switchAria')}>
        {langLinks.map((l, i) => (
          <>
            {i > 0 && <span class="nav__lang-sep" aria-hidden="true">·</span>}
            {l.code === lang ? (
              <span class="nav__lang-current" aria-current="true">{l.label}</span>
            ) : (
              <a class="nav__lang-link" href={l.href} hreflang={l.code === 'en' ? 'en' : 'pt-BR'}>{l.label}</a>
            )}
          </>
        ))}
      </div>
    </div>
  </div>
</nav>

<style>
  .nav {
    padding-block: 24px;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav__brand {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.04em;
    color: var(--text);
    display: inline-flex;
    align-items: center;
  }

  .nav__brand-full {
    display: inline;
  }

  .nav__brand-mark {
    display: none;
    width: 32px;
    height: 32px;
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .nav__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 15px;
  }

  .nav__sep {
    color: var(--text-muted);
  }

  .nav__lang {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 14px;
    letter-spacing: 0.04em;
    padding-left: 16px;
    border-left: 1px solid var(--divider);
  }

  .nav__lang-current {
    color: var(--accent);
    font-weight: 600;
  }

  .nav__lang-link {
    color: var(--text-muted);
    text-decoration: none;
  }

  .nav__lang-link:hover {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .nav__lang-sep {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .nav__brand-full {
      display: none;
    }
    .nav__brand-mark {
      display: inline-block;
    }
    .nav__item {
      font-size: 14px;
    }
    .nav__right {
      gap: 12px;
    }
    .nav__lang {
      padding-left: 12px;
    }
  }
</style>
