---
interface Props {
  title: string;
  description: string;
  meta: string;
  href: string;
}

const { title, description, meta, href } = Astro.props;
---

<a href={href} class="card">
  <div class="card__slot" aria-hidden="true"></div>
  <div class="card__body">
    <h3 class="card__title">{title}</h3>
    <p class="card__description">{description}</p>
    <p class="card__meta">
      <span>{meta}</span>
      <span aria-hidden="true" class="card__arrow">→</span>
    </p>
  </div>
</a>

<style>
  .card {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: center;
    padding: 32px 24px;
    margin-inline: -24px;
    color: inherit;
    text-decoration: none;
    transition: background-color 150ms ease-out, color 150ms ease-out;
  }

  .card__slot {
    aspect-ratio: 4 / 3;
    background: var(--slot-empty);
    width: 100%;
    transition: background-color 150ms ease-out;
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    line-height: 1.15;
  }

  .card__description {
    font-size: 16px;
    line-height: 1.5;
    color: var(--text);
  }

  .card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 15px;
    color: var(--text-muted);
    transition: color 150ms ease-out;
  }

  .card__arrow {
    font-family: var(--font-display);
  }

  @media (hover: hover) and (pointer: fine) {
    .card:hover {
      background: var(--accent);
      color: var(--bg);
    }
    .card:hover .card__description,
    .card:hover .card__meta {
      color: var(--bg);
    }
    .card:hover .card__slot {
      background: rgba(250, 250, 247, 0.12);
    }
  }

  @media (max-width: 640px) {
    .card {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 24px 16px;
      margin-inline: -16px;
    }
    .card__title {
      font-size: 24px;
    }
  }
</style>
